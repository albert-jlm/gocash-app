# .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── App ────────────────────────────────────────────
APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Supabase (Client — safe to expose) ─────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Monitoring ─────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ─── Push Notifications (Phase 2) ───────────────────
# APNs and FCM credentials — added when push notifications are implemented
# APNS_KEY_ID=
# APNS_TEAM_ID=
# FCM_SERVER_KEY=

# =================================================================
# NOTE: The following secrets belong in Supabase Edge Function env
# vars — NOT in this file. Set them via: supabase secrets set
# =================================================================
# OPENAI_API_KEY          ← OpenAI API key (GPT-4O + gpt-4.1-mini)
# SUPABASE_SERVICE_ROLE_KEY ← Supabase service role key
